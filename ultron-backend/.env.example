# ── ULTRON Backend Configuration ──
# Copy to .env and adjust values for your environment.
# All variables have sensible defaults; only override what you need.

# ── Application Identity ──
APP_NAME=ULTRON
APP_VERSION=1.0.0
DEVICE_ID=RPi4-ULTRON-001
MACHINE_ID=RAV-01

# ── Server ──
HOST=0.0.0.0
PORT=8000
BROADCAST_INTERVAL_MS=100
SIMULATED=true                     # Set to false on real hardware

# ── Sensor Ranges (bar / °C) ──
PRESSURE_MIN=4.0
PRESSURE_MAX=11.0
TEMPERATURE_MIN=50.0
TEMPERATURE_MAX=115.0

# ── Database (SQLite) ──
DB_ENABLED=true
DB_PATH=./data/ultron.db
DB_RETENTION_DAYS=30
DB_BATCH_INTERVAL_S=1

# ── Modbus TCP ──
MODBUS_TCP_ENABLED=true
MODBUS_TCP_HOST=0.0.0.0
MODBUS_TCP_PORT=5020
MODBUS_BYTE_ORDER=ABCD

# ── Modbus RTU (serial) ──
MODBUS_RTU_ENABLED=false
MODBUS_RTU_PORT=/dev/ttyUSB0
MODBUS_RTU_BAUDRATE=9600

# ── mDNS Discovery ──
MDNS_ENABLED=true
MDNS_HOSTNAME=ultron-edge
DEVICE_NAME=ULTRON Edge

# ── Logging ──
LOG_LEVEL=INFO
LOG_DIR=logs
