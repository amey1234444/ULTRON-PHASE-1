# ── Docker Compose Environment Variables ──
# Copy to .env and adjust for your deployment.

# Port bindings
BACKEND_PORT=8000
DASHBOARD_PORT=3000
MODBUS_TCP_PORT=5020

# Backend configuration
SIMULATED=true
BROADCAST_INTERVAL_MS=100
DB_ENABLED=true
DB_RETENTION_DAYS=30
LOG_LEVEL=INFO

# Sensor ranges
PRESSURE_MIN=4.0
PRESSURE_MAX=11.0
TEMPERATURE_MIN=50.0
TEMPERATURE_MAX=115.0
